{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-config-os/contracts/v1/momentum-view.schema.json",
  "title": "MomentumView",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "work_title",
    "progress_summary",
    "top_findings",
    "current_strength",
    "best_next_action"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "task_id": { "type": "string", "minLength": 1 },
    "work_title": { "type": "string", "minLength": 1 },
    "progress_summary": { "type": "string", "minLength": 1 },
    "top_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["summary"],
        "properties": {
          "summary": { "type": "string", "minLength": 1 },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "verification_status": { "type": "string" }
        }
      }
    },
    "current_strength": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "label"],
      "properties": {
        "level": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "best_next_action": { "type": "string", "minLength": 1 },
    "upgrade_opportunity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_label": { "type": "string", "minLength": 1 },
        "unlocks": { "type": "string", "minLength": 1 }
      }
    }
  }
}

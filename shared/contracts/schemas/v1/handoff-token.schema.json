{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-config-os/contracts/v1/handoff-token.schema.json",
  "title": "HandoffToken",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "token_id", "task_id", "issued_at", "expires_at", "signature", "replay_nonce"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "token_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "task_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "signature": { "type": "string", "pattern": "^[a-f0-9]+$" },
    "replay_nonce": { "type": "string", "minLength": 1 }
  }
}

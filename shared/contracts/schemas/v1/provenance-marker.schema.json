{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-config-os/contracts/v1/provenance-marker.schema.json",
  "title": "ProvenanceMarker",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "recorded_at", "recorded_by_route"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "status": { "type": "string", "enum": ["verified", "reused", "hypothesis"] },
    "recorded_at": { "type": "string", "format": "date-time" },
    "recorded_by_route": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "note": { "type": "string", "minLength": 1 }
  }
}

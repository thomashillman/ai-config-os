{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-config-os/contracts/v1/progress-event.schema.json",
  "title": "ProgressEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "event_id",
    "type",
    "message",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "type": {
      "type": "string",
      "enum": [
        "state_change",
        "route_selected",
        "finding_recorded",
        "finding_transitioned",
        "continuation_created",
        "narration_shown",
        "user_response"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  }
}

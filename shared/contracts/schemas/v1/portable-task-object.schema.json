{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-config-os/contracts/v1/portable-task-object.schema.json",
  "title": "PortableTaskObject",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "task_type",
    "goal",
    "current_route",
    "state",
    "progress",
    "findings",
    "unresolved_questions",
    "approvals",
    "route_history",
    "next_action",
    "version",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "task_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "task_type": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "goal": { "type": "string", "minLength": 1 },
    "current_route": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "state": {
      "type": "string",
      "enum": ["pending", "active", "blocked", "completed", "failed"]
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completed_steps", "total_steps"],
      "properties": {
        "completed_steps": { "type": "integer", "minimum": 0 },
        "total_steps": { "type": "integer", "minimum": 0 }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "findings-ledger-entry.schema.json" }
    },
    "unresolved_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "approvals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "route_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["route", "selected_at"],
        "properties": {
          "route": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "selected_at": { "type": "string", "format": "date-time" },
          "selection_reference": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "digest": { "type": "string", "minLength": 1 },
              "revision": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "execution_selections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["digest", "revision", "selected_at", "route_id"],
        "properties": {
          "digest": { "type": "string", "minLength": 1 },
          "revision": { "type": "string", "minLength": 1 },
          "selected_at": { "type": "string", "format": "date-time" },
          "route_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        }
      }
    },
    "next_action": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}

{
  "enabledMcpjsonServers": ["cloudflare"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-use.sh\"",
            "description": "Dispatcher for all PreToolUse event-driven rules (guard, logging)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use.sh\"",
            "description": "Dispatcher for all PostToolUse event-driven rules (analytics, reminders)"
          }
        ]
      }
    ]
  }
}

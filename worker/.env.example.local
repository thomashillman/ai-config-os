# Local Development Environment Variables
# Copy this to .env.local for local `wrangler dev` testing
# This file should NOT be committed to git

# ============================================================================
# LOCAL SECRETS (for wrangler dev only)
# ============================================================================
# For local testing, you can set these here. For production/staging,
# always use: wrangler secret put <NAME> --env <ENV>

AUTH_TOKEN=local-test-token-12345
EXECUTOR_SHARED_SECRET=local-test-secret-67890
AUTH_TOKEN_NEXT=local-next-token-optional
HANDOFF_TOKEN_SIGNING_KEY=local-signing-key-optional

# ============================================================================
# LOCAL RUNTIME VARIABLES
# ============================================================================
ENVIRONMENT=development
EXECUTOR_PROXY_URL=http://localhost:8788
EXECUTOR_TIMEOUT_MS=10000

# ============================================================================
# LOCAL CLOUDFLARE RESOURCES
# ============================================================================
# For local testing, you can:
# 1. Leave KV/R2 unbound → Worker falls back to embedded registry
# 2. Or bind to actual staging/production KV/R2 namespaces by updating wrangler.toml
#
# For this .env.local, no changes needed. KV/R2 are optional.

# Staging Deployment Environment Variables
# Copy this to a real .env.staging file and fill in actual values
# This file should NOT be committed to git

# ============================================================================
# WORKER SECRETS (set via: wrangler secret put <NAME> --env staging)
# ============================================================================
# Do NOT include secrets in this file. Secrets must be set via wrangler CLI.
# For local testing only, you can optionally set these in a .env.local file:
#
#   AUTH_TOKEN=your-staging-token-here
#   EXECUTOR_SHARED_SECRET=your-shared-secret-here

# ============================================================================
# WORKER ENVIRONMENT VARIABLES (from wrangler.toml)
# ============================================================================
# These are defined in wrangler.toml [env.staging.vars]
# Update them there, not here.

# ENVIRONMENT=staging
# EXECUTOR_PROXY_URL=https://executor-staging.example.com
# EXECUTOR_TIMEOUT_MS=10000

# ============================================================================
# CLOUDFLARE RESOURCES (from wrangler.toml)
# ============================================================================
# Update the namespace ID and bucket name in wrangler.toml:
# - In [env.staging.kv_namespaces]: set id to your staging KV namespace ID
# - In [env.staging.r2_buckets]: update bucket_name if needed
#
# Get these values from Cloudflare:
# 1. KV namespace ID: https://dash.cloudflare.com/ -> KV Namespaces -> staging-manifest-kv -> Bindings
# 2. R2 bucket name: https://dash.cloudflare.com/ -> R2 -> ai-config-os-artefacts-staging

STAGING_MANIFEST_KV_ID=your-kv-namespace-id-here
STAGING_R2_BUCKET_NAME=ai-config-os-artefacts-staging

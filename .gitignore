# Local Claude Code settings
.claude/settings.local.json

# Local-only overrides
overrides/

# OS junk
.DS_Store
Thumbs.db

# Editor configs (uncomment to track)
# .vscode/
# .idea/

# Skill testing & analytics (generated, local-only)
shared/test-results/
~/.claude/skill-analytics/

# Generated commands (surface-aware skills materialized to .claude/commands/)
.claude/commands/*.md
.claude/commands/.generated-skills.json

# Runtime: machine-specific and project-local config
runtime/config/machines/*.yaml
runtime/config/project.yaml

# Runtime: manifest state (generated)
runtime/manifest.yaml

# Dashboard: build artifacts
dashboard/dist/
dashboard/node_modules/

# Build system
dist/
node_modules/
package-lock.json

# Local runtime cache (generated by session-start.sh)
.ai-config-os/
